# API_BASE points at the 24/7 LAN server so dev mode (and any same-origin
# assumption) talks to the real backend.  Local-only devs using
# python -m api.main should flip this back to http://localhost:8000.
VITE_API_BASE=http://localhost:8000  # Flipped to localhost for v0.9 local testing (was: http://192.168.100.101:8000)
