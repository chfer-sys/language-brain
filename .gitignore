# .env is committed so VITE_API_BASE is documented and the 24/7 server
# address is consistent across machines.  It contains no secrets.
.env.*
__pycache__/
*.pyc
node_modules/
.svelte-kit/
build/
dist/
# Vault contents are runtime artifacts. The directory structure
# (vault/index/, vault/units/{sentences,words,groups}/) is preserved
# via .gitkeep files. Anything else under vault/ is generated by tests
# or the reindex script and must NOT be committed.
vault/index/*.npy
vault/index/faiss.index
vault/index/*.json
# v0.5.1 SQLite runtime store — gitignored; vault.dump.sql is the git mirror
vault/index/vault.db*
vault/index/*.corrupt.bak*
# v0.5.2 id counter — runtime state, incremented by next_id on every new unit
vault/_meta/id_counters.json
# v0.5.3 dictionary source CSV — gitignored; download at first-run
vault/index/sources/
vault/units/**/*.json
*.egg-info/
.pytest_cache/
.coverage
.DS_Store
*.log

# Playwright MCP runtime / screenshots (design docs in .specs/design-*.md
# are the canonical design-review artifacts; PNGs are local-only).
.playwright-mcp/
.specs/screenshots/
.osgrep
