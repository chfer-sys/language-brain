# ops/deploy.sh.env.example
# Copy to ops/deploy.sh and fill in the values.
# deploy.sh reads these via `source`, so only use shell-compatible assignment.
#
# SECURITY: deploy.sh is gitignored — do NOT commit the real file with a real key.

# Required
LANGUAGE_BRAIN_AI_KEY='sk-cp-YOUR_KEY_HERE'

# Optional overrides (defaults match what the container image expects)
# LANGUAGE_BRAIN_AI_ENDPOINT='https://api.minimax.io/v1'
# LANGUAGE_BRAIN_AI_MODEL='MiniMax-M2.1'
# LANGUAGE_BRAIN_VAULT='/app/vault'
